# Copy this to .env for local development. On Render, set VITE_GA_MEASUREMENT_ID
# under the static site's Environment settings instead (see README.md).

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX).
# Get this from GA4 Admin -> Data Streams -> your web stream -> Measurement ID.
# Leave blank to disable GA4 entirely (custom backend tracking still works either way).
VITE_GA_MEASUREMENT_ID=
